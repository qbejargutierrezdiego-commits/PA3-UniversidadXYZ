{
  "ReverseProxy": {
    "Routes": {
      "estudiantesRoute": {
        "ClusterId": "estudiantesCluster",
        "Match": {
          "Path": "/api/estudiantes/{**catch-all}"
        }
      },
      "cursosRoute": {
        "ClusterId": "cursosCluster",
        "Match": {
          "Path": "/api/cursos/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "estudiantesCluster": {
        "Destinations": {
          "destino1": {
            "Address": "http://localhost:5274/"
          }
        }
      },
      "cursosCluster": {
        "Destinations": {
          "destino1": {
            "Address": "http://localhost:5222/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
